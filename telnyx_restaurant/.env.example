# Copy to .env for local use (do not commit .env)
#
# Telnyx / security (set on Render)
# TELNYX_WEBHOOK_SECRET=

# Postgres (Render: paste Internal or External Database URL)
# DB_URI=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# (sqlalchemy uses psycopg2; sslmode=require is appended automatically for *.render.com hosts)

# Optional: protect /admin/reservations?token=
# ADMIN_DASHBOARD_TOKEN=change-me-long-random

# Browser UI: /reservation-lab — create / lookup / amend / cancel / delete / canned scenarios (off by default).
# On public hosts, set ADMIN_DASHBOARD_TOKEN and open /reservation-lab?token=...
# HANOK_RESERVATION_LAB=1

# Outbound reminder demo (~5s after POST /api/reservations, threading.Timer — not BackgroundTasks)
# TELNYX_API_KEY=KEY0179...   (API V2 key from Mission Control)
# TELNYX_CONNECTION_ID=...   Must be the Voice API "Call Control Application" id used with POST /v2/calls
# TELNYX_FROM_NUMBER=+1555... Your verified outbound caller ID (+E.164)

# Public origin for outbound Call Control webhook override (no trailing slash)
# HANOK_PUBLIC_BASE_URL=https://telnyx.convonetai.com
# HANOK_REMINDER_DELAY_SECONDS=5

# Timezone for slot normalization
# RESTAURANT_TZ=America/New_York

# Log full (truncated) PATCH bodies for /amend and …/status at INFO (Render logs)
# HANOK_RESERVATION_VERBOSE_LOG=1

# Table allocation (optional): inventory per 30m slot, multi-slot duration, waitlist, cancel → promote
# HANOK_TABLE_ALLOCATION_ENABLED=1
# HANOK_TABLE_SLOT_MINUTES=30
# HANOK_RESERVATION_DURATION_MINUTES=120
# HANOK_MAX_TABLES_PER_PARTY=2
# HANOK_TABLE_INVENTORY_JSON={"4":2,"6":3,"8":3,"10":2}
# HANOK_VIP_PREORDER_CENTS=50000
# Guest-facing ETA in dynamic variables: position × minutes (default 15; e.g. 1st→15m, 2nd→30m)
# HANOK_WAITLIST_MINUTES_PER_POSITION=15
# Max weighted waitlist units for one slot+duration (multi-table parties count extra); over cap → 409 — suggest ~2h earlier/later (default 5)
# HANOK_WAITLIST_MAX_PER_SLOT=5
# Log failed table allocation (eff / maps) at INFO when allocation looks wrong
# HANOK_RESERVATION_VERBOSE_LOG=1

# MCP server (python -m telnyx_restaurant.mcp_server) — REST origin it calls
# HANOK_MCP_API_BASE_URL=https://telnyx.convonetai.com
# HANOK_MCP_TRANSPORT=stdio
# Same Render service: streamable HTTP MCP for Telnyx “Type: HTTP” (URL = public origin + path)
# HANOK_MCP_HTTP_MOUNT=1
# HANOK_MCP_HTTP_MOUNT_PATH=/mcp
# MCP streamable HTTP validates Host/Origin when HANOK_PUBLIC_BASE_URL (or MCP API URL) is set — add extras if needed:
# HANOK_MCP_ALLOWED_HOSTS=other.hostname
# HANOK_MCP_ALLOWED_ORIGINS=https://other.hostname
# HANOK_MCP_DISABLE_DNS_REBINDING=1
# MCP tool HTTP client timeout seconds (default 45; max 120)
# HANOK_MCP_HTTP_TIMEOUT_SECONDS=45

# Voice: merge duplicate POST /api/reservations within this window (same phone + slot + party); 0=off
# HANOK_VOICE_CREATE_DEDUP_SECONDS=120
