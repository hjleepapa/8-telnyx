# Copy to .env.cloudrun and fill in real values. DO NOT COMMIT .env.cloudrun.
# Set these in Cloud Run (Console or gcloud run services update) per service; they persist across rebuilds.
# REDIS_DB must be a number (0-15) for Redis; use 0 for Redis Cloud single DB.

# --- Redis (Redis Cloud) - all services that use Redis ---
REDIS_HOST=
REDIS_PORT=17434
REDIS_PASSWORD=
REDIS_DB=0

# --- Postgres (Render) ---
# Use full host in DB_URI (e.g. dpg-xxx-a.oregon-postgres.render.com) or set RENDER_POSTGRES_HOST_SUFFIX so short host is fixed.
DB_URI=
RENDER_POSTGRES_HOST_SUFFIX=.oregon-postgres.render.com

# --- LLM ---
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# --- STT ---
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
CARTESIA_API_KEY=
CARTESIA_STT_MODEL=ink-whisper
MODULATE_API_KEY=

# --- Voice gateway WebSocket (/webrtc/ws): STT/TTS providers (voice-gateway-service only) ---
# VOICE_STT_PROVIDER=deepgram | elevenlabs | cartesia | speechmatics
# VOICE_TTS_PROVIDER=deepgram | elevenlabs | cartesia | speechmatics
VOICE_STT_PROVIDER=deepgram
VOICE_TTS_PROVIDER=deepgram
DEEPGRAM_VOICE_ID=aura-asteria-en
ELEVENLABS_VOICE_ID=
CARTESIA_VOICE_ID=
SPEECHMATICS_API_KEY=
# Preview TTS voices: sarah | theo | megan | jack
SPEECHMATICS_TTS_VOICE=sarah

# --- TTS ---
ELEVENLABS_API_KEY=
CARTESIA_TTS_MODEL=sonic-3
CARTESIA_TTS_EMOTION=calm
CARTESIA_TTS_SPEED=0.88
CARTESIA_TTS_VOLUME=0.85
CARTESIA_VERSION=2025-04-16
RIME_API_KEY=
INWORLD_API_KEY=
INWORLD_CHARACTER_ID=
INWORLD_WORKSPACE=

# --- SuiteCRM (crm-integration-service) ---
SUITECRM_BASE_URL=
SUITECRM_CLIENT_ID=
SUITECRM_CLIENT_SECRET=
SUITECRM_USERNAME=
SUITECRM_PASSWORD=
DATABASE_URL=

# --- Voice / Twilio (voice-gateway-service) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_TRANSFER_CALLER_ID=
FREEPBX_DOMAIN=
AGENT_LLM_URL=
# Voice PIN: set ENABLE_VOICE_PIN=true to require PIN. If DB_URI is set, PIN is validated against users_anthropic.voice_pin; else VOICE_PIN env.
ENABLE_VOICE_PIN=false
VOICE_PIN=1234

# --- Optional: LiveKit (not used on GCP voice-gateway; only WebRTC/FastAPI WebSocket) ---
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_ENABLED=
# LIVEKIT_INPUT_ENABLED=

# --- Optional: auth / LangSmith ---
# JWT_SECRET_KEY=
# LANGSMITH_TRACING_V2=
# LANGSMITH_ENDPOINT=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH2_TOKEN_B64=
# SQLALCHEMY_DATABASE_URI=
